{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Foodstore Quick Reference",
  "description": "Quick reference guide for developers working on Foodstore",
  "version": "2.1.1",
  "repository": {
    "url": "https://github.com/qtuanph/ChipmeoFoodstore.git",
    "branch": "master"
  },
  "projects": {
    "FoodstoreApi": {
      "path": "FoodstoreApi",
      "type": ".NET 10 Web API",
      "description": "Clean Architecture backend — REST API, SignalR, JWT auth",
      "commands": {
        "run": "dotnet run --project FoodstoreApi.Web",
        "build": "dotnet build",
        "restore": "dotnet restore",
        "publish": "dotnet publish -c Release",
        "migration_add": "dotnet ef migrations add <Name> --project FoodstoreApi.Web",
        "migration_apply": "dotnet ef database update --project FoodstoreApi.Web",
        "migration_remove": "dotnet ef migrations remove --project FoodstoreApi.Web"
      },
      "port": 5142,
      "startup": "FoodstoreApi.Web/Program.cs",
      "solution": "FoodstoreApi.slnx"
    },
    "MediaStorageManagement": {
      "path": "MediaStorageManagement",
      "type": ".NET 10 Minimal API",
      "description": "Standalone media file server (images uploads, static serving)",
      "commands": {
        "run": "dotnet run --project MediaStorageManagement",
        "build": "dotnet build",
        "publish": "dotnet publish -c Release"
      },
      "auth": "X-Api-Key header",
      "solution": "MediaStorageManagement.slnx"
    },
    "Store": {
      "path": "foodstore-store",
      "type": "SvelteKit 2 + Svelte 5",
      "description": "Frontend — POS, Admin Dashboard, Kitchen Display",
      "commands": {
        "dev": "npm run dev",
        "build": "npm run build",
        "preview": "npm run preview",
        "prepare": "npm run prepare",
        "check": "npm run check",
        "format": "npm run format",
        "lint": "npm run lint"
      },
      "port": 5173,
      "proxy": {
        "/api": "http://localhost:5142",
        "/hubs": "http://localhost:5142 (ws)"
      }
    },
    "LandingPage": {
      "path": "foodstore-landingpage",
      "type": "Astro 7",
      "description": "Landing Page — static site, SEO-friendly",
      "commands": {
        "dev": "npm run dev",
        "build": "npm run build",
        "preview": "npm run preview"
      },
      "port": 4321
    }
  },
  "environments": {
    "development": {
      "api_url": "http://localhost:5142",
      "frontend_url": "http://localhost:5173",
      "media_url": "http://localhost:5000"
    },
    "production": {
      "api_url": "https://api.foodstore.local",
      "frontend_url": "https://food.foodstore.local",
      "media_url": "https://media.foodstore.local"
    },
    "demo": {
      "frontend_url": "https://foodstore.vercel.app"
    }
  },
  "key_patterns": {
    "api_auth": "JWT Bearer token from POST /api/auth/login",
    "media_auth": "X-Api-Key header (configured in MediaStorageManagement/appsettings.json)",
    "frontend_config": "Store/src/lib/config/index.ts — auto-detects env",
    "icon_format": "Use <Icon icon=\"tabler:icon-name\" /> — Tabler Icons via @iconify/svelte",
    "db_connection": "FoodstoreApi/FoodstoreApi.Web/appsettings.json → ConnectionStrings.DefaultConnection",
    "e_invoice_provider": "IEInvoiceProvider interface + IEInvoiceProviderFactory — pluggable provider implementations"
  },
  "architecture": {
    "backend": "Clean Architecture (4 layers)",
    "frontend": "SvelteKit file-based routing + Next.js 16 admin dashboard",
    "realtime": "SignalR hub at /hubs/app (MessagePack protocol)",
    "auth": "JWT Bearer tokens + custom permission-based RBAC",
    "database": "PostgreSQL 18 + EF Core 10 + Npgsql",
    "caching": "IMemoryCache (TTL: 60-300s)",
    "rate_limiting": "Global 100 req/min, Auth 60 req/min",
    "ml": "ML.NET TimeSeries for sales forecasting",
    "e_invoice": "Multi-provider factory pattern (Viettel, MISA)"
  },
  "tech_stack": {
    "frontend": {
      "language": "TypeScript 6/7",
      "framework": "Svelte 5 + SvelteKit 2 / Next.js 16 + React 19",
      "build_tool": "Vite 8 (Rolldown/Oxc) / Turbopack",
      "styling": "Tailwind CSS 4",
      "editor": "TipTap 3.28",
      "icons": "@iconify/svelte 5 / lucide-react",
      "charts": "ApexCharts 5 / Recharts 3",
      "realtime": "@microsoft/signalr 10",
    "image_cropping": "Croppie 2",
    "flowbite": "Vanilla JS (programmatic API)"
  },
    "backend": {
      "framework": "ASP.NET Core 10",
      "orm": "Entity Framework Core 10",
      "database": "PostgreSQL 18",
      "auth": "JWT Bearer + Better Auth (BFF)",
      "realtime": "SignalR + MessagePack",
      "ml": "Microsoft.ML 5"
    }
  }
}
