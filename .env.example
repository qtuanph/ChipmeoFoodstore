# PostgreSQL
POSTGRES_USER=YOUR_VALUE_HERE
POSTGRES_DB=YOUR_VALUE_HERE
DB_PASSWORD=YOUR_VALUE_HERE

# Redis
REDIS_PASSWORD=YOUR_VALUE_HERE

# S3 (RustFS) — S3-compatible object storage
S3_ACCESS_KEY=YOUR_VALUE_HERE
S3_SECRET_KEY=YOUR_VALUE_HERE
S3_BUCKET=YOUR_VALUE_HERE

# Backend API
ASPNETCORE_ENVIRONMENT=YOUR_VALUE_HERE
JWT_SECRET=YOUR_VALUE_HERE

# Frontend
PUBLIC_API_URL=YOUR_VALUE_HERE

# Auth storage prefix (tránh conflict với app khác trên cùng domain)
PUBLIC_AUTH_STORAGE_PREFIX=YOUR_VALUE_HERE

# SignalR
PUBLIC_SIGNALR_HUB=YOUR_VALUE_HERE
PUBLIC_SIGNALR_WS_ONLY=YOUR_VALUE_HERE

# QR Payment
PUBLIC_VIETQR_API_URL=YOUR_VALUE_HERE
PUBLIC_DEFAULT_QR_TEMPLATE=YOUR_VALUE_HERE

# SEO
PUBLIC_SITE_DOMAIN=YOUR_VALUE_HERE

# Default password cho khách hàng POS
PUBLIC_DEFAULT_CUSTOMER_PASSWORD=YOUR_VALUE_HERE

# Internal Docker URL cho admin Next.js proxy (Docker internal DNS)
API_INTERNAL_URL=YOUR_VALUE_HERE

# SvelteKit ORIGIN (dùng để xác định origin trong production)
ORIGIN=YOUR_VALUE_HERE
